# Local-only example config. Do not commit real secrets or operational credentials.
APP_NAME=supply-program-engine
ENV=dev

# Local runtime data path. The default file ledger is ignored by git.
LEDGER_BACKEND=file
LEDGER_PATH=data/ledger.jsonl
DATABASE_URL=postgresql+psycopg://spe:spe_password@localhost/spe

# Secrets and admin access
HMAC_SECRET=replace-me
ADMIN_API_KEY=replace-me
SESSION_SECRET=replace-me
SESSION_COOKIE_NAME=spe_operator_session
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# In ENV=dev, demo-admin / dev-password is available when OPERATOR_USERS_JSON is unset.
OPERATOR_USERS_JSON=

# Discovery / enrichment
GOOGLE_PLACES_API_KEY=replace-me
GOOGLE_PLACES_TEXT_SEARCH_URL=https://places.googleapis.com/v1/places:searchText
DISCOVERY_MODE=mock
DISCOVERY_QUERY=formwork contractor
DISCOVERY_REGION=Texas

ENRICHMENT_FETCH_TIMEOUT_SECONDS=5
ENRICHMENT_USER_AGENT=supply-program-engine-enrichment/1.0

OUTBOUND_PROVIDER=mock
OUTBOUND_DRY_RUN=true
OUTBOUND_FROM_EMAIL=operator@example.internal
OUTBOUND_FROM_NAME=Supply Program
OUTBOUND_REPLY_TO_EMAIL=
OUTBOUND_PROVIDER_API_KEY=

# Policy / suppression
SEND_POLICY_RISK_THRESHOLD=3
SUPPRESSED_ENTITIES=
SUPPRESSED_DOMAINS=
REPLY_TEXT_RETENTION_DAYS=30
REDACTION_PLACEHOLDER=[redacted]

# Queue / worker
QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=spe:tasks
WORKER_ENABLED=false
WORKER_POLL_TIMEOUT_SECONDS=5

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=supply-program-engine
OTEL_EXPORTER_TYPE=console
